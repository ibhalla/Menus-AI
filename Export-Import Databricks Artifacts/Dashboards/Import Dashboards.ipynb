import os
import json
from databricks.sdk import WorkspaceClient
from databricks.sdk.service.dashboards import Dashboard

# Initialize the client
w_target = WorkspaceClient()

# Set the folder to where the uploaded dashboards are stored
workspace_folder_path = "//Workspace/Users/ibhalla@infomedia.com.au/Deployment/Notebooks/Dashboards"

print("Starting Databricks Dashboard import...")

# Loop through the unzipped folder looking for the JSON files
for filename in os.listdir(workspace_folder_path):
    if filename.endswith(".lvdash.json"):
        file_path = os.path.join(workspace_folder_path, filename)
        
        # The display name is the file name without the extension
        display_name = filename.replace(".lvdash.json", "")
        
        try:
            # Open and read the unzipped JSON file
            with open(file_path, "r", encoding="utf-8") as f:
                dash_data = json.load(f)
            
            # The API expects the dashboard definition as a JSON string
            serialized_data = json.dumps(dash_data)
            
            # Create the dashboard in the workspace using the Dashboard object
            w_target.lakeview.create(
                dashboard=Dashboard(
                    display_name=display_name,
                    serialized_dashboard=serialized_data
                )
            )
            print(f"✅ Successfully imported: {display_name}")
            
        except Exception as e:
            print(f"❌ Error importing {display_name}: {e}")

print("Import complete!")
